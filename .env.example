FIRMS_MAP_KEY=changeme
PORT=8080
DB_PATH=/data/pyrmap.db
LOG_LEVEL=info
# Optional: EUMETSAT Data Store credentials (https://api.eumetsat.int/api-key/ after registering
# at https://eoportal.eumetsat.int). When set, Meteosat MTG fire alerts feed the fast geo tier.
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=
# Optional: LSA SAF Data Service credentials (register at https://mokey.lsasvcs.ipma.pt/auth/signup).
# When set, the MSG FRP-PIXEL raw fire-detection list feeds the geo tier alongside EUMETSAT MTG —
# it. has no significance threshold, so it catches small fires the CAP bulletin above misses.
LSASAF_USERNAME=
LSASAF_PASSWORD=
# Optional: X API v2 app-only Bearer Token (developer.x.com, pay-per-use billing — see README).
# When set, the Greek Fire Service's own X posts (@pyrosvestiki) are geocoded onto a separate,
# lower-trust "reported incidents" layer.
X_BEARER_TOKEN=
# Optional: single-user login. All three must be set together, or the site stays fully open
# (the default — convenient for local dev, not what you want for a public deployment).
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_USERNAME=
AUTH_PASSWORD=
SESSION_SECRET=
# Optional: Web Push credentials for browser/OS notifications on new detections. Generate with:
# cd packages/server && pnpm exec web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: contact (required by the Web Push protocol for abuse contact).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
# Optional: GA4 Measurement ID (e.g. G-XXXXXXXXXX) from analytics.google.com — create a GA4
# property + Web data stream for the deployed domain and copy its Measurement ID here. NOT a
# secret (it's always visible in any page's source) but this is a BUILD-TIME value: Vite bakes it
# into the static JS bundle when the frontend is built, unlike every other var in this file, which
# is read at container runtime. See Dockerfile/docker-compose.yml for how it's plumbed through as
# a build-arg. Leave empty for local dev — a real ID here would mix local testing into the real
# GA4 property's data.
VITE_GA_MEASUREMENT_ID=
# Optional: absolute host path for the SQLite data volume (docker-compose.yml only, not read by
# the app itself). Needed for Portainer GitOps deploys — a relative ./data would resolve inside
# Portainer's ephemeral git-clone directory and be deleted on stack recreation. Defaults to
# ./data for plain local `docker compose up`.
HOST_DATA_DIR=
