FIRMS_MAP_KEY=changeme
PORT=8080
DB_PATH=/data/pyrmap.db
LOG_LEVEL=info
# Optional: EUMETSAT Data Store credentials (https://api.eumetsat.int/api-key/ after registering
# at https://eoportal.eumetsat.int). When set, Meteosat MTG fire alerts feed the fast geo tier.
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=
# Optional: LSA SAF Data Service credentials (register at https://mokey.lsasvcs.ipma.pt/auth/signup).
# When set, the MSG FRP-PIXEL raw fire-detection list feeds the geo tier alongside EUMETSAT MTG —
# it has no significance threshold, so it catches small fires the CAP bulletin above misses.
LSASAF_USERNAME=
LSASAF_PASSWORD=
# Optional: X API v2 app-only Bearer Token (developer.x.com, pay-per-use billing — see README).
# When set, the Greek Fire Service's own X posts (@pyrosvestiki) are geocoded onto a separate,
# lower-trust "reported incidents" layer.
X_BEARER_TOKEN=
# Optional: single-user login. All three must be set together, or the site stays fully open
# (the default — convenient for local dev, not what you want for a public deployment).
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_USERNAME=
AUTH_PASSWORD=
SESSION_SECRET=
